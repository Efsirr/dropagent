# DropAgent — environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# ── Database ──────────────────────────────────────────────────────────────
# Defaults to SQLite (dropagent.db) when not set.
# For production use PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dropagent
DATABASE_URL=sqlite:///./dropagent.db

# ── Telegram Bot ──────────────────────────────────────────────────────────
# Required to run the bot. Get yours from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── eBay (Model 1 — US Arbitrage) ────────────────────────────────────────
# Finding API App ID from developer.ebay.com
EBAY_APP_ID=your_ebay_app_id_here

# ── Amazon Product Advertising API (Model 1) ─────────────────────────────
# PA-API 5.0 credentials from affiliate-program.amazon.com
AMAZON_ACCESS_KEY=your_amazon_access_key_here
AMAZON_SECRET_KEY=your_amazon_secret_key_here
AMAZON_PARTNER_TAG=your_amazon_partner_tag_here

# ── Walmart Affiliate API (Model 1) ──────────────────────────────────────
# API key from developer.walmart.com
WALMART_API_KEY=your_walmart_api_key_here

# ── AliExpress API (Model 2 — China Dropshipping) ────────────────────────
# From AliExpress Open Platform (aliexpress.com/developer)
ALIEXPRESS_APP_KEY=your_aliexpress_app_key_here
ALIEXPRESS_APP_SECRET=your_aliexpress_app_secret_here
ALIEXPRESS_TRACKING_ID=your_aliexpress_tracking_id_here

# ── CJDropshipping API (Model 2) ─────────────────────────────────────────
# API key from app.cjdropshipping.com
CJ_API_KEY=your_cj_api_key_here

# ── Dashboard Server ──────────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
