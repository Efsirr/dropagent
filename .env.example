# DropAgent environment template
#
# Important:
# - The app reads only `.env` at runtime.
# - `.env.example` is just a safe template stored in git.
# - For local development, keep one real system file: `.env`.
# - Copy this file to `.env` once, then work only with `.env`.
#
# Keep it simple:
# 1. Fill the "Minimum to start" section first.
# 2. Leave optional integrations blank until you actually need them.
# 3. Never commit your real `.env`.

# ============================================================================
# Minimum to start
# ============================================================================
# For the first local real test, fill this single list only.

DATABASE_URL=sqlite:///./dropagent.db
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
APP_SECRET_KEY=
DASHBOARD_PUBLIC_URL=http://127.0.0.1:8000
EBAY_APP_ID=
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# Where to get each value:
# - DATABASE_URL: keep the default sqlite value for the easiest local start.
# - TELEGRAM_BOT_TOKEN: create a bot in @BotFather and paste the token here.
# - APP_SECRET_KEY: generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# - DASHBOARD_PUBLIC_URL: use http://127.0.0.1:8000 for local Docker testing.
# - EBAY_APP_ID: create an app in the eBay developer portal and copy the App ID.
# - DASHBOARD_HOST / DASHBOARD_PORT: keep the defaults for local Docker testing.

# Optional for hosted webhook mode only:
# TELEGRAM_WEBHOOK_SECRET=

# ============================================================================
# Optional source integrations
# ============================================================================
# Fill only the providers you actually want to use.

# Amazon Product Advertising API
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=

# Walmart
WALMART_API_KEY=

# AliExpress
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
ALIEXPRESS_TRACKING_ID=

# CJDropshipping
CJ_API_KEY=

# ============================================================================
# Optional research / intelligence integrations
# ============================================================================
# These improve discovery and validation, but are not required to boot the app.

KEEPA_API_KEY=
STORELEADS_API_KEY=
PIPIADS_API_KEY=
MINEA_API_KEY=
SIMILARWEB_API_KEY=
ZIK_API_KEY=

# ============================================================================
# Optional notifications / exports
# ============================================================================
DISCORD_WEBHOOK_URL=
EMAIL_FROM=
EMAIL_TO=
GOOGLE_SHEETS_ID=

# ============================================================================
# Optional Supabase client values
# ============================================================================
# Not required by the current backend, but useful if you later expose
# frontend-side Supabase features or want the values documented in one place.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
